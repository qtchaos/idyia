# Drizzle
# Replace with your DB credentials!
DATABASE_URL=libsql://db-name-user.turso.io
# A local DB can also be used in dev as well
# DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# Better Auth — Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Cloudflare Turnstile
# Leave blank to disable Turnstile (useful in local dev).
# Cloudflare also provides always-passing test keys:
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
